{
  "name": "@partner-up-dev/design-web",
  "version": "0.1.0",
  "description": "PartnerUp Design System for Web",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "sass": "./src/styles/index.scss",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/partner-up-dev/design.git",
    "directory": "packages/web"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "style": "./dist/style.css",
      "sass": "./src/styles/index.scss",
      "default": "./dist/index.js"
    },
    "./styles": {
      "sass": "./src/styles/index.scss",
      "default": "./dist/style.css"
    },
    "./styles/*": {
      "sass": "./src/styles/*",
      "default": "./src/styles/*"
    },
    "./components/*": "./src/components/*",
    "./utils/*": "./src/utils/*",
    "./uno": {
      "import": "./src/styles/unocss-preset.ts"
    },
    "./types": {
      "types": "./types/components.d.ts"
    }
  },
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "files": [
    "dist",
    "src/components",
    "src/styles",
    "src/utils",
    "types"
  ],
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "clean": "rimraf dist",
    "build": "pnpm run clean && vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly"
  },
  "keywords": [
    "partnerup",
    "design-system",
    "web",
    "vue3",
    "components"
  ],
  "author": "PartnerUp Team",
  "license": "MIT",
  "peerDependencies": {
    "sass": "^1.70.0",
    "unocss": "^0.60.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "unocss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "rimraf": "^6.1.3",
    "sass": "^1.70.0",
    "typescript": "^5.3.0",
    "unocss": "^0.60.3",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "packageManager": "pnpm@10.28.1"
}
