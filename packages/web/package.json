{
  "name": "@partner-up-dev/design-web",
  "version": "0.1.2",
  "description": "PartnerUp Design System for Web",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "sass": "./src/styles/index.scss",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/partner-up-dev/design.git",
    "directory": "packages/web"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "style": "./dist/style.css",
      "sass": "./src/styles/index.scss",
      "default": "./dist/index.js"
    },
    "./styles": {
      "sass": "./src/styles/index.scss",
      "default": "./dist/style.css"
    },
    "./styles/*": {
      "sass": "./src/styles/*",
      "default": "./src/styles/*"
    },
    "./components/*": "./src/components/*",
    "./utils/*": "./src/utils/*",
    "./uno": {
      "import": "./src/styles/unocss-preset.ts"
    },
    "./types": {
      "types": "./types/components.d.ts"
    }
  },
  "sideEffects": [
    "*.css",
    "*.scss",
    "*.vue"
  ],
  "files": [
    "dist",
    "skills",
    "src/components",
    "src/styles",
    "src/utils",
    "types"
  ],
  "scripts": {
    "dev": "pnpm run story:dev",
    "preview": "vite preview",
    "generate": "node scripts/generate-component-registry.mjs",
    "generate:check": "node scripts/generate-component-registry.mjs --check",
    "skill:generate": "node scripts/generate-agent-skill.mjs",
    "skill:generate:check": "node scripts/generate-agent-skill.mjs --check",
    "skill:validate": "intent validate",
    "skill:stale": "intent stale",
    "story:dev": "histoire dev",
    "story:build": "histoire build",
    "story:coverage": "node scripts/check-story-coverage.mjs",
    "type-check": "pnpm run generate:check && pnpm run skill:generate:check && vue-tsc --noEmit",
    "clean": "rimraf dist",
    "build": "pnpm run generate && pnpm run clean && vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "verify": "pnpm run type-check && pnpm run skill:validate && pnpm run build && pnpm run story:coverage && pnpm run story:build"
  },
  "keywords": [
    "partnerup",
    "design-system",
    "web",
    "vue3",
    "components",
    "tanstack-intent"
  ],
  "author": "PartnerUp Team",
  "license": "MIT",
  "peerDependencies": {
    "sass": "^1.94.2",
    "unocss": "^66.6.8",
    "vue": "^3.5.34"
  },
  "peerDependenciesMeta": {
    "unocss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@histoire/controls": "1.0.0-beta.1",
    "@histoire/plugin-vue": "1.0.0-beta.1",
    "@iconify-json/mdi": "^1.2.3",
    "@tanstack/intent": "^0.0.41",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "histoire": "1.0.0-beta.1",
    "rimraf": "^6.1.3",
    "sass": "^1.94.2",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.3.0",
    "unocss": "^66.6.8",
    "vite": "^7.3.3",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@10.28.1"
}
