{
  "name": "@partner-up/design-uniapp",
  "version": "0.1.1",
  "description": "PartnerUp Design System for UniApp",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/partner-up-dev/design.git",
    "directory": "packages/uniapp"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./styles": "./lib/styles/index.css",
    "./styles/*": "./lib/styles/*",
    "./sass": "./src/styles/index.scss",
    "./sass/*": "./src/styles/*"
  },
  "files": [
    "lib",
    "src/styles",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit"
  },
  "keywords": [
    "partnerup",
    "design-system",
    "uniapp",
    "vue3",
    "components"
  ],
  "author": "PartnerUp Team",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "packageManager": "pnpm@10.23.0"
}
