{
  "name": "@partner-up-dev/design-uniapp",
  "version": "0.2.0",
  "description": "PartnerUp Design System for UniApp",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "types/components.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/partner-up-dev/design.git",
    "directory": "packages/uniapp"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./types/components.d.ts"
    },
    "./styles": {
      "sass": "./src/styles/index.scss",
      "default": "./src/styles/index.scss"
    },
    "./styles/*": {
      "sass": "./src/styles/*",
      "default": "./src/styles/*"
    },
    "./components/*": "./src/components/*",
    "./utils/*": "./src/utils/*"
  },
  "files": [
    "src/components",
    "src/styles",
    "types"
  ],
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "copy": "copyfiles -u 1 \"src/**/*.{vue,ts,json,scss}\" dist",
    "clean": "rimraf dist",
    "build": "pnpm run clean && pnpm run copy"
  },
  "keywords": [
    "partnerup",
    "design-system",
    "uniapp",
    "vue3",
    "components"
  ],
  "author": "PartnerUp Team",
  "license": "MIT",
  "peerDependencies": {
    "sass": "^1.70.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "packageManager": "pnpm@10.28.1"
}